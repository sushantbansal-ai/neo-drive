// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id                            String                   @id
  type                          String
  location                      String
  availableFromTime             String
  availableToTime               String
  availableDays                 String[]                 @default([])
  minimumMinutesBetweenBookings Int                      @default(15)
  createdAt                     DateTime                 @default(now())
  updatedAt                     DateTime                 @updatedAt
  reservations                  Reservation[]
  reservationStats              VehicleReservationStats?

  @@index([type, location])
}

model Reservation {
  id            Int      @id @default(autoincrement())
  vehicleId     String
  startDateTime DateTime @db.Timestamptz(3)
  endDateTime   DateTime @db.Timestamptz(3)
  customerName  String
  customerEmail String
  customerPhone String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  @@index([vehicleId, startDateTime, endDateTime])
  @@index([startDateTime, endDateTime])
}

model VehicleReservationStats {
  vehicleId                  String    @id
  reservationCount           Int       @default(0)
  lastReservationEndDateTime DateTime? @db.Timestamptz(3)
  updatedAt                  DateTime  @updatedAt
  vehicle                    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([reservationCount, lastReservationEndDateTime], map: "VehicleReservationStats_reservationCount_lastReservationEnd_idx")
}
